SQUARE_ACCESS_TOKEN=your_square_sandbox_access_token
SQUARE_LOCATION_ID=your_square_location_id
SQUARE_WEBHOOK_SIGNATURE=your_webhook_signature_key

# ── Resend ────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
# Important: avoid blank assignments like KEY= with no value.
# Blank values are treated as unset and can change fallback behavior.
# Production sender(s): must be from your verified domain in Resend
RESEND_FROM=SparkClean <bookings@yourdomain.com>
# Optional split sender identities
RESEND_FROM_CUSTOMER=SparkClean <bookings@yourdomain.com>
RESEND_FROM_OWNER=SparkClean Bookings <bookings@yourdomain.com>
# Optional local testing override: send all outgoing emails to one inbox.
# Example: RESEND_DEV_TO=you@example.com
# To disable, remove this line entirely instead of leaving it blank.
RESEND_DEV_TO=you@example.com

# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
DIRECT_URL=postgresql://user:pass@host/dbname?sslmode=require

# ── App ───────────────────────────────────────────────
# Local dev: your ngrok URL (e.g. https://abc123.ngrok-free.app)
# Production: your public app URL
NEXT_PUBLIC_URL=https://abc123.ngrok-free.app

# The email address that receives booking notifications
BOOKING_NOTIFICATION_EMAIL=your@email.com.au
OWNER_EMAIL=your@email.com.au

# COPY THIS FILE TO .env.local AND FILL IN THE VALUES BEFORE RUNNING THE APP